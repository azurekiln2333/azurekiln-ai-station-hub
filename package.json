{
  "name": "azurekiln-ai-hub",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w web\"",
    "dev:web": "npm run dev -w web",
    "dev:server": "npm run dev -w server",
    "db:seed": "npm run db:seed -w server",
    "build": "npm run build -w web",
    "preview": "npm run preview -w web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.8.0"
  }
}
